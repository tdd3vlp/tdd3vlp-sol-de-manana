generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Chat {
  id                      String            @id @default(cuid())
  telegramChatId          String            @unique
  currentTheme            String
  themeReplyCount         Int               @default(0)
  plan                    String            @default("free")
  planExpiresAt           DateTime?
  mode                    String            @default("dialogue")
  lockTheme               Boolean           @default(false)
  dailyMessageCount       Int               @default(0)
  dailyResetAt            DateTime          @default(now())
  customerEmail           String?
  pendingPaymentPlan      String?
  streakCount                  Int               @default(0)
  lastStreakDate               String?
  weeklyActiveDates            String            @default("[]")
  weeklyResetAt                DateTime?
  challengeCompletedCount      Int               @default(0)
  dailyPracticeSentenceCount   Int               @default(0)
  dailyPracticeCompletedAt     DateTime?
  dailyPracticeResetAt         DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  messages                Message[]
  practiceSessions        PracticeSession[]
}

model PracticeSession {
  id          String    @id @default(cuid())
  chatId      String
  date        String
  dayNumber   Int
  theme       String
  stepCount   Int       @default(0)
  status      String    @default("active")
  highlights  String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  chat        Chat      @relation(fields: [chatId], references: [id])

  @@unique([chatId, date])
  @@index([chatId])
}

model Payment {
  id                      String    @id @default(cuid())
  telegramChatId          String
  plan                    String
  amount                  Int
  currency                String
  telegramPaymentChargeId String    @unique
  providerPaymentChargeId String?
  isRecurring             Boolean   @default(false)
  expiresAt               DateTime?
  createdAt               DateTime  @default(now())
  // Added in migration add_yookassa_direct: "telegram" for Stars/old provider-token
  // payments; "yookassa" for direct API payments. providerPaymentId holds the
  // ЮKassa payment.id (telegramPaymentChargeId contains "yk:<id>" for these rows).
  paymentProvider         String    @default("telegram")
  providerPaymentId       String?
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  text      String
  llmJson   String?
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // getRecentMessages filters by chatId and sorts by createdAt on every
  // user message; Postgres does not index FK columns automatically.
  @@index([chatId, createdAt])
}

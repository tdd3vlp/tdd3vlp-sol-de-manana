TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
# Models per plan: free uses OPENAI_MODEL_FREE, basic/premium use OPENAI_MODEL_PAID.
# OPENAI_MODEL_TRANSLATE handles the Russian spoiler translation under bot replies.
OPENAI_MODEL_FREE=gpt-4o-mini
OPENAI_MODEL_PAID=gpt-4o
OPENAI_MODEL_TRANSLATE=gpt-4o-mini
DATABASE_URL=postgresql://sol:sol@localhost:5432/sol_de_manana
NODE_ENV=development

# Subscription
ADMIN_TELEGRAM_IDS=

# Web App (subscription page) — deploy webapp/index.html and set the public URL here
WEBAPP_URL=

# ── Direct ЮKassa API (for RUB payments: СБП, T-Pay, card) ──────────────────
# Get SHOP_ID and SECRET_KEY from ЮKassa dashboard → Integrations → API.
# Both must be set together or both left empty (Stars-only mode).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Random secret path segment for the ЮKassa webhook endpoint.
# Generate with: openssl rand -hex 32
# Register in ЮKassa dashboard: https://api.soldemanana.ru/webhooks/yookassa/<token>
YOOKASSA_WEBHOOK_TOKEN=

# 54-ФЗ fiscal receipts are enabled in the ЮKassa shop: every payment is
# created with a receipt (vat_code 1, "без НДС"), and the bot collects the
# customer email before generating the payment link.

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=3001
PUBLIC_BASE_URL=https://api.soldemanana.ru

# Telegram deep link for ЮKassa payment return_url (e.g. https://t.me/your_bot)
TELEGRAM_BOT_URL=

# ── Observability ─────────────────────────────────────────────────────────────
# Telegram chat/channel ID to receive critical error alerts. Leave empty to disable.
ERROR_CHANNEL_ID=

# Legacy Telegram Payments provider token — no longer used for RUB, kept for reference.
YOOKASSA_PROVIDER_TOKEN=

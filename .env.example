TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
# Models per plan: free uses OPENAI_MODEL_FREE, basic/premium use OPENAI_MODEL_PAID.
# OPENAI_MODEL_TRANSLATE handles the Russian spoiler translation under bot replies.
OPENAI_MODEL_FREE=gpt-4o-mini
OPENAI_MODEL_PAID=gpt-4o
OPENAI_MODEL_TRANSLATE=gpt-4o-mini
DATABASE_URL=postgresql://sol:sol@localhost:5432/sol_de_manana
NODE_ENV=development

# Subscription
ADMIN_TELEGRAM_IDS=

# Web App (subscription page) — deploy webapp/index.html and set the public URL here
WEBAPP_URL=

# Telegram payment provider token from BotFather → Payments → YooKassa.
# Leave empty to offer Telegram Stars only.
YOOKASSA_PROVIDER_TOKEN=
